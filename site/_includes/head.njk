  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  {%- if env == "production" %}
  <script async src="https://www.googletagmanager.com/gtag/js?id={{ site.ga }}"></script>
  <script>window.dataLayer=window.dataLayer||[];function gtag(){dataLayer.push(arguments);}gtag('js',new Date());gtag('config','{{ site.ga }}');</script>
  {%- endif %}
  {%- set fullTitle %}{% if pageTitle %}{{ pageTitle }} — {% endif %}{{ site.title }}{% endset %}
  <title>{{ fullTitle }}</title>
  <meta name="description" content="{{ pageDescription or site.description }}">
  <link rel="canonical" href="{{ site.url }}{{ page.url }}">
  <meta name="application-name" content="{{ site.title }}">
  <meta name="author" content="{{ site.author.name }}">
  <meta name="robots" content="index, follow">
  <meta property="og:site_name" content="{{ site.title }}">
  <meta property="og:type" content="website">
  <meta property="og:url" content="{{ site.url }}{{ page.url }}">
  <meta property="og:title" content="{{ fullTitle }}">
  <meta property="og:description" content="{{ pageDescription or site.description }}">
  <meta property="og:image" content="{{ site.url }}/assets/brand/og-image.png">
  <meta property="og:locale" content="en_US">
  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:title" content="{{ fullTitle }}">
  <meta name="twitter:description" content="{{ pageDescription or site.description }}">
  <meta name="twitter:image" content="{{ site.url }}/assets/brand/og-image.png">
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "WebSite",
    "name": "{{ site.title }}",
    "alternateName": ["Mermaid for Google Docs™", "Mermaid Add-on", "Google Docs™ Mermaid Plugin"],
    "url": "{{ site.url }}",
    "description": "{{ site.description }}",
    "author": {
      "@type": "Person",
      "name": "{{ site.author.name }}",
      "url": "{{ site.author.url }}"
    }
  }
  </script>
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "Organization",
    "name": "{{ site.author.name }}",
    "url": "{{ site.author.url }}",
    "logo": "{{ site.url }}/assets/brand/icon-128.png",
    "sameAs": [
      "https://github.com/numanaral"
    ]
  }
  </script>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Space+Mono:wght@400;700&family=Outfit:wght@300;400;500;600;700;800&display=swap">
  <link rel="icon" href="/favicon.ico" sizes="any">
  <link rel="icon" href="/assets/brand/icon-32.png" type="image/png" sizes="32x32">
  <link rel="apple-touch-icon" href="/assets/brand/icon-128.png">
