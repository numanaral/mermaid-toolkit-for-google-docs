---
permalink: /
layout: base.njk
pageCss: index
sitemapPriority: 1.0
---
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "SoftwareApplication",
  "name": "{{ site.title }}",
  "url": "{{ site.url }}/",
  "description": "{{ site.description }}",
  "applicationCategory": "Productivity",
  "operatingSystem": "Web",
  "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" },
  "author": { "@type": "Person", "name": "{{ site.author.name }}", "url": "{{ site.author.url }}" }
}
</script>
  <main>
  <!-- HERO -->
  <section class="hero">
    <div class="orb orb-1"></div>
    <div class="orb orb-2"></div>
    <div class="orb orb-3"></div>
    <div class="pending-banner">
      <strong>⏳ Awaiting Google Verification</strong>
      Currently undergoing branding verification by Google's Trust &amp; Safety team. The Marketplace listing will be submitted for review once verification is complete. Install link coming soon!
    </div>
    <hr class="hero-divider">
    <div class="hero-center">
      <div class="hero-badge"><img src="/assets/brand/icon-32.png" alt=""> <span class="dot"></span> Google Docs™ Add-on</div>
      <h1>Code to <span class="gradient">diagram</span> in seconds.</h1>
      <p>Write Mermaid syntax in Google Docs™, render it as a polished diagram. Everything stays in your browser.</p>
      <div class="hero-actions">
        {# TODO: Replace # with actual Marketplace URL once published #}
        <a href="#" class="btn-accent">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
          Install from Marketplace
        </a>
        <a href="https://github.com/numanaral/mermaid-toolkit-for-google-docs" class="btn-dim" target="_blank" rel="noopener">GitHub →</a>
      </div>
      <div class="hero-stats">
        <div class="stat"><div class="val">0</div><div class="label">Data collected</div></div>
        <div class="stat"><div class="val">100%</div><div class="label">Client-side</div></div>
        {% set diagramCount = [] %}{% for d in diagrams %}{% if not d.isAlias %}{% set _ = diagramCount.push(1) %}{% endif %}{% endfor %}<div class="stat"><div class="val">{{ diagramCount | length }}</div><div class="label">Diagram types</div></div>
      </div>
    </div>
  </section>

  <!-- DEMO -->
  <section class="demo-section" id="demo">
    <div class="demo-inner">
      <div class="section-header reveal">
        <div class="tag">See it in action</div>
        <h2>From code to diagram in one click.</h2>
      </div>
      <div class="demo-video reveal">
        <video autoplay loop muted playsinline controls poster="/assets/screenshots/editor.png">
          <source src="/assets/screenshots/demo.webm" type="video/webm">
        </video>
      </div>
    </div>
  </section>

  <!-- WHY MERMAID TOOLKIT -->
  <section class="why" id="why">
    <div class="why-inner">
      <div class="section-header reveal">
        <div class="tag">Why Mermaid Toolkit</div>
        <h2>Diagrams that work everywhere.</h2>
      </div>
      <div class="why-grid reveal-stagger">
        <div class="card why-card">
          <div class="why-icon">🤖</div>
          <h3>AI-Friendly Workflows</h3>
          <p>Mermaid diagrams are plain text. Copy them between Google Docs, your IDE, and AI tools without dealing with images or format issues.</p>
        </div>
        <div class="card why-card">
          <div class="why-icon">📋</div>
          <h3>Markdown Interop</h3>
          <p>Export as markdown, paste into GitHub, Notion, or any markdown editor. Import back into Google Docs and re-render — no conversion needed.</p>
        </div>
        <div class="card why-card">
          <div class="why-icon">🔒</div>
          <h3>Zero Data Collection</h3>
          <p>Everything renders client-side via Mermaid.js — even for complex diagram types that trigger browser security restrictions. No servers, no analytics, no cookies. Your diagrams never leave your browser.</p>
        </div>
        <div class="card why-card">
          <div class="why-icon">🔄</div>
          <h3>Round-Trip Editing</h3>
          <p>Every diagram stores its source code. Click any diagram to edit, update, or extract the original Mermaid syntax.</p>
        </div>
        <div class="card why-card">
          <div class="why-icon">⚡</div>
          <h3>Bulk Operations</h3>
          <p>Scan your entire document and convert all code blocks to diagrams in one click. Or extract all diagrams back to code.</p>
        </div>
        <div class="card why-card">
          <div class="why-icon">🛠️</div>
          <h3>Fix Native "Copy as Markdown"</h3>
          <p>Google Docs' "Copy as Markdown" mangles Mermaid syntax. The built-in fixer repairs vertical tabs, stray backticks, and formatting artifacts automatically.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- BENTO FEATURES -->
  <section class="bento" id="features">
    <div class="bento-inner">
      <div class="section-header reveal">
        <div class="tag">What it does</div>
        <h2>Built for speed and privacy.</h2>
      </div>
      <div class="bento-grid reveal-stagger">
        {% set ns = { i: 0 } %}
        {% for feat in features %}{% if feat.showInBento %}
        {% if ns.i % 2 == 0 %}<div class="bento-row{{ ' bento-row-flip' if (ns.i / 2) | round(0, 'floor') % 2 == 1 }}">{% endif %}
        <div class="card bento-card"><div class="card-icon">{{ feat.icon }}</div><h3>{{ feat.title }}</h3><p>{{ feat.shortDesc | safe }}</p></div>
        {% if ns.i % 2 == 1 or loop.last %}</div>{% endif %}
        {% set ns = { i: ns.i + 1 } %}
        {% endif %}{% endfor %}
      </div>
    </div>
  </section>

  <!-- GETTING STARTED (Tabbed Showcase) -->
  <section class="how" id="how">
    <div class="how-inner">
      <div class="section-header reveal">
        <div class="tag">Getting Started</div>
        <h2>Five ways to work with diagrams.</h2>
      </div>
      <div class="how-tabs reveal">
        {% for workflow in howto %}
        <button class="how-tab{{ ' active' if loop.first }}" data-tab="{{ workflow.id }}">{{ workflow.subtitle }}</button>
        {% endfor %}
      </div>
      <div class="how-panels">
        {% for workflow in howto %}
        <div class="how-panel{{ ' active' if loop.first }}" id="how-panel-{{ workflow.id }}">
          <div class="how-panel-screenshot">
            <img src="{{ workflow.screenshot }}" alt="{{ workflow.subtitle }}" loading="lazy">
          </div>
          <div class="how-panel-content">
            <p class="how-panel-desc">{{ workflow.desc }}</p>
            <ol class="how-steps">
              {% for step in workflow.steps %}
              <li>
                <div>
                  <h4>{{ step.title }}</h4>
                  <p>{{ step.desc | safe }}</p>
                </div>
              </li>
              {% endfor %}
            </ol>
          </div>
        </div>
        {% endfor %}
      </div>
      <div class="callout reveal">
        <strong>Heads up:</strong> The first line of your code block must be a diagram type keyword.
        <div class="callout-compare">
          <div class="callout-do">
            <span class="callout-label do">Do</span>
            <div class="code-block"><div class="code-line">graph TD</div><div class="code-line hl-ok">  %% comments after line 1 are ok!</div><div class="code-line">  A --&gt; B</div><div class="code-line">  B --&gt; C</div><div class="code-line">  C --&gt; D</div></div>
          </div>
          <div class="callout-dont">
            <span class="callout-label dont">Don't</span>
            <div class="code-block"><div class="code-line hl-bad">%% this breaks detection!</div><div class="code-line">graph TD</div><div class="code-line">  A --&gt; B</div><div class="code-line">  B --&gt; C</div><div class="code-line">  C --&gt; D</div></div>
          </div>
        </div>
      </div>
      <div class="callout reveal">
        <strong>Tip:</strong> New to the add-on? Open <strong>Extensions → Mermaid Toolkit → Quick Guide</strong> for an interactive walkthrough right inside Google Docs.
      </div>
    </div>
  </section>

  <!-- DIAGRAMS -->
  <section class="diagrams" id="diagrams">
    <div class="diagrams-inner">
      <div class="tag reveal">Compatibility</div>
      <h2 class="reveal">Every diagram type you need.</h2>
      <div class="diagram-cards reveal-stagger">
        {% for d in diagrams %}{% if d.hasCard %}
        <a href="{{ d.docsUrl }}" class="card diagram-card" target="_blank" rel="noopener">
          <picture><source srcset="/assets/diagrams/diagram-{{ d.slug }}.webp" type="image/webp"><img src="/assets/diagrams/diagram-{{ d.slug }}.png" alt="{{ d.name }}" loading="lazy"></picture>
          <span>{{ d.name }}</span>
        </a>
        {% endif %}{% endfor %}
      </div>
      <div class="chip-cloud reveal">
        {% for d in diagrams %}
        <a href="{{ d.docsUrl }}" target="_blank" rel="noopener">{{ d.keyword }}</a>
        {% endfor %}
      </div>
      <div class="diagrams-footer reveal">
        <a href="/gallery" class="btn-dim">View Full Gallery →</a>
        <span class="diagrams-ref">Reference at <a href="https://mermaid.js.org/" target="_blank" rel="noopener">mermaid.js.org</a></span>
      </div>
    </div>
  </section>

  </main>
