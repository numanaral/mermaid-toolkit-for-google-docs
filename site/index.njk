---
permalink: /
layout: base.njk
---
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "SoftwareApplication",
  "name": "{{ site.title }}",
  "url": "{{ site.url }}/",
  "description": "{{ site.description }}",
  "applicationCategory": "Productivity",
  "operatingSystem": "Web",
  "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" },
  "author": { "@type": "Person", "name": "{{ site.author.name }}", "url": "{{ site.author.url }}" }
}
</script>
  <main>
  <!-- HERO -->
  <section class="hero">
    <div class="orb orb-1"></div>
    <div class="orb orb-2"></div>
    <div class="orb orb-3"></div>
    <div class="pending-banner">
      <strong>⏳ Awaiting Google Verification</strong>
      Currently undergoing branding verification by Google's Trust &amp; Safety team. The Marketplace listing will be submitted for review once verification is complete. Install link coming soon!
    </div>
    <hr class="hero-divider">
    <div class="hero-two-col">
      <div class="hero-content">
        <div class="hero-badge"><img src="/assets/icon-32.png" alt=""> <span class="dot"></span> Google Docs™ Add-on</div>
        <h1>Code to <span class="gradient">diagram</span> in seconds.</h1>
        <p>Write Mermaid syntax in Google Docs™, render it as a polished image. Everything stays in your browser.</p>
        <div class="hero-actions">
          {# TODO: Replace # with actual Marketplace URL once published #}
          <a href="#" class="btn-accent">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
            Install from Marketplace
          </a>
          <a href="https://github.com/numanaral/mermaid-toolkit-for-google-docs?utm_source=website&utm_medium=hero&utm_campaign=mermaid_toolkit" class="btn-dim">GitHub →</a>
        </div>
        <div class="hero-stats">
          <div class="stat"><div class="val">0</div><div class="label">Data collected</div></div>
          <div class="stat"><div class="val">100%</div><div class="label">Client-side</div></div>
          <div class="stat"><div class="val">17</div><div class="label">Diagram types</div></div>
        </div>
      </div>
      <div class="hero-demo">
        <svg viewBox="0 0 560 380" xmlns="http://www.w3.org/2000/svg" role="img" aria-label="Demo video placeholder">
          <rect width="560" height="380" rx="16" fill="#111818"/>
          <rect x="1" y="1" width="558" height="378" rx="15" fill="none" stroke="rgba(74,234,204,0.15)" stroke-width="1"/>
          <circle cx="280" cy="175" r="36" fill="none" stroke="rgba(74,234,204,0.4)" stroke-width="2"/>
          <polygon points="270,158 300,175 270,192" fill="rgba(74,234,204,0.5)"/>
          <text x="280" y="240" text-anchor="middle" fill="rgba(74,234,204,0.5)" font-family="Space Mono,monospace" font-size="13">TODO: demo video</text>
        </svg>
      </div>
    </div>
  </section>

  <!-- BENTO FEATURES -->
  <section class="bento" id="features">
    <div class="bento-inner">
      <div class="section-header reveal">
        <div class="tag">Features</div>
        <h2>Built for speed and privacy.</h2>
      </div>
      <div class="bento-grid reveal-stagger">
        {% for feat in features %}{% if feat.showInBento %}
        <div class="card bento-card{{ ' wide' if feat.wide }}"><div class="card-icon">{{ feat.icon }}</div><h3>{{ feat.title }}</h3><p>{{ feat.shortDesc | safe }}</p></div>
        {% endif %}{% endfor %}
      </div>
    </div>
  </section>

  <!-- SHOWCASE -->
  <section class="showcase" id="showcase">
    <div class="showcase-inner">
      <div class="section-header reveal">
        <div class="tag">In Action</div>
        <h2>See it in action.</h2>
      </div>
      <div class="showcase-tabs reveal">
        {% for feat in features %}{% if feat.showInShowcase %}
        <button data-img="{{ feat.showcaseImg or '' }}">{{ feat.showcaseLabel }}</button>
        {% endif %}{% endfor %}
      </div>
      <div class="showcase-window reveal">
        <div class="window-bar"><div class="window-dot r"></div><div class="window-dot y"></div><div class="window-dot g"></div></div>
        <picture><source srcset="/assets/example-render-all-for-all.webp" type="image/webp"><img id="ss" src="/assets/example-render-all-for-all.png" alt="Screenshot" width="1212" height="642" loading="eager"></picture>
      </div>
    </div>
  </section>

  <!-- GETTING STARTED -->
  <section class="how" id="how">
    <div class="how-inner">
      <div class="section-header reveal">
        <div class="tag">Getting Started</div>
        <h2>Three ways to work with diagrams.</h2>
      </div>
      <div class="how-grid reveal-stagger">
        {% for workflow in howto %}
        <div class="how-col{{ ' how-col-full' if loop.index > 2 }}">
          <h3 class="how-subtitle">{{ workflow.subtitle }}</h3>
          <p class="how-subtitle-desc">{{ workflow.desc }}</p>
          <div class="timeline">
            {% for step in workflow.steps %}
            <div class="tl-item"><h4>{{ step.title }}</h4><p>{{ step.desc | safe }}</p></div>
            {% endfor %}
          </div>
        </div>
        {% endfor %}
      </div>
      <div class="callout reveal">
        <strong>Heads up:</strong> The first line of your code block must be a diagram type keyword.
        <div class="callout-compare">
          <div class="callout-do">
            <span class="callout-label do">Do</span>
            <div class="code-block"><div class="code-line">graph TD</div><div class="code-line hl-ok">  %% comments after line 1 are ok!</div><div class="code-line">  A --&gt; B</div><div class="code-line">  B --&gt; C</div><div class="code-line">  C --&gt; D</div></div>
          </div>
          <div class="callout-dont">
            <span class="callout-label dont">Don't</span>
            <div class="code-block"><div class="code-line hl-bad">%% this breaks detection!</div><div class="code-line">graph TD</div><div class="code-line">  A --&gt; B</div><div class="code-line">  B --&gt; C</div><div class="code-line">  C --&gt; D</div></div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- DIAGRAMS -->
  <section class="diagrams" id="diagrams">
    <div class="diagrams-inner">
      <div class="tag reveal">Compatibility</div>
      <h2 class="reveal">Every diagram type you need.</h2>
      <div class="diagram-cards reveal-stagger">
        {% for d in diagrams %}{% if d.hasCard %}
        <a href="{{ d.docsUrl }}" class="card diagram-card" target="_blank" rel="noopener">
          <picture><source srcset="/assets/diagram-{{ d.slug }}.webp" type="image/webp"><img src="/assets/diagram-{{ d.slug }}.png" alt="{{ d.name }}" loading="lazy"></picture>
          <span>{{ d.name }}</span>
        </a>
        {% endif %}{% endfor %}
      </div>
      <div class="chip-cloud reveal">
        {% for d in diagrams %}
        <a href="{{ d.docsUrl }}" target="_blank" rel="noopener">{{ d.keyword }}</a>
        {% endfor %}
      </div>
      <div class="diagrams-footer reveal">
        <a href="/gallery" class="btn-dim">View Full Gallery →</a>
        <span class="diagrams-ref">Reference at <a href="https://mermaid.js.org/">mermaid.js.org</a></span>
      </div>
    </div>
  </section>

  </main>
