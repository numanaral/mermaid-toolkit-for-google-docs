---
permalink: /gallery/
layout: base.njk
pageTitle: Diagram Gallery
pageDescription: "Live-rendered examples of every Mermaid diagram type supported by Mermaid Toolkit for Google Docs™."
pageJs: gallery
pageCss: gallery
---

  <section class="page-hero gallery-hero">
    <div class="orb orb-1"></div>
    <div class="orb orb-2"></div>
    <h1 class="reveal">Diagram Gallery</h1>
    <p class="reveal">Live-rendered examples of every diagram type supported by Mermaid Toolkit for Google Docs™.</p>
  </section>

  <div class="gallery-grid">

    {% for diagram in diagrams %}
    {% if not diagram.isAlias %}
    <div class="card gallery-item" data-mermaid='{{ diagram.code | safe }}'>
      <div class="gallery-item-header"><h3>{{ diagram.name }}</h3><div class="gallery-links"><button onclick="this.closest('.gallery-item').querySelector('.gallery-item-code').classList.toggle('open')">source</button><a href="{{ diagram.docsUrl }}" target="_blank" rel="noopener">docs →</a></div></div>
      <div class="gallery-item-render"><span class="mermaid-placeholder">Loading…</span></div>
      <div class="gallery-item-code"><pre>{{ diagram.code | safe }}</pre></div>
    </div>
    {% endif %}
    {% endfor %}

  </div>
