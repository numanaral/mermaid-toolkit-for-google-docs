---
permalink: /changelog/
layout: base.njk
pageTitle: Changelog
pageDescription: "Release notes for Mermaid Toolkit for Google Docs™ — scope changes, new features, bug fixes, and migration notes."
pageCss: legal
sitemapPriority: 0.4
---
<main>
  <section class="page-hero">
    <h1>Changelog</h1>
    {% if changelog.intro %}{{ changelog.intro | safe }}{% endif %}
  </section>
  <div class="legal">
    {% for release in changelog.versions %}
    <article class="changelog-entry" id="{{ release.id }}">
      <h2>
        <a href="#{{ release.id }}" class="anchor-link" aria-label="Link to {{ release.version }}">#</a>
        {{ release.version }}{% if release.tagline %} — {{ release.tagline }}{% endif %}
      </h2>
      {% if release.date %}<p class="changelog-date"><time datetime="{{ release.date }}">{{ release.date }}</time></p>{% endif %}
      {{ release.html | safe }}
    </article>
    {% endfor %}
  </div>
</main>
