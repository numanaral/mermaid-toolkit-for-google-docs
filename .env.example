# ---- Apps Script (clasp) ----
# Your Apps Script project ID for clasp push/pull.
# To find yours: open your Apps Script project -> Project Settings -> Script ID.
# Contributors: create a new Apps Script project in a test Google Doc and use that ID.
#
# After setting this, create .clasp.json in the repo root:
#   { "scriptId": "YOUR_SCRIPT_ID", "rootDir": "dist/gas" }
#
# Both .env and .clasp.json are gitignored.
CLASP_SCRIPT_ID=your-script-id-here
