{
  "name": "mermaid-toolkit-for-google-docs",
  "version": "1.0.0",
  "private": true,
  "description": "Render Mermaid diagrams as images directly in Google Docs.",
  "scripts": {
    "build:css": "sass site/styles/main.scss:_site/styles/main.css site/styles/page-gallery.scss:_site/styles/gallery.css site/styles/page-features.scss:_site/styles/features.css --style=compressed --no-source-map",
    "build:js": "esbuild site/scripts/main.ts site/scripts/gallery.ts --bundle --outdir=_site/scripts --minify --target=es2020",
    "build:11ty": "npx @11ty/eleventy",
    "build": "npm-run-all build:css build:js build:11ty",
    "watch:css": "sass site/styles/main.scss:_site/styles/main.css site/styles/page-gallery.scss:_site/styles/gallery.css site/styles/page-features.scss:_site/styles/features.css --watch",
    "watch:js": "esbuild site/scripts/main.ts site/scripts/gallery.ts --bundle --outdir=_site/scripts --watch --target=es2020",
    "watch:11ty": "npx @11ty/eleventy --serve",
    "dev": "npm-run-all --parallel watch:css watch:js watch:11ty"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/numanaral/mermaid-toolkit-for-google-docs.git"
  },
  "author": "Numan Aral",
  "license": "MIT",
  "devDependencies": {
    "@11ty/eleventy": "^3.1.2",
    "esbuild": "^0.27.3",
    "npm-run-all2": "^8.0.4",
    "sass": "^1.97.3"
  }
}
