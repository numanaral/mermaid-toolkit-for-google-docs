{
  "name": "mermaid-toolkit-for-google-docs",
  "version": "1.0.0",
  "private": true,
  "description": "Render Mermaid diagrams as images directly in Google Docs.",
  "scripts": {
    "site:dev": "bash scripts/dev.sh",
    "site:build": "bash scripts/build.sh",
    "site:lint": "eslint site/ scripts/build.sh scripts/dev.sh",
    "site:lint:fix": "eslint site/ --fix",
    "site:typecheck": "tsc --noEmit -p tsconfig.json",
    "gas:dev": "tsx scripts/dev-gas.ts",
    "gas:build": "tsx scripts/build-gas.ts",
    "gas:push": "tsx scripts/push.ts",
    "gas:preview": "tsx scripts/build-gas.ts && tsx scripts/preview-gas.ts",
    "gas:login": "clasp login",
    "gas:lint": "eslint src/gas/ scripts/build-gas.ts scripts/dev-gas.ts scripts/push.ts",
    "gas:lint:fix": "eslint src/gas/ scripts/build-gas.ts scripts/dev-gas.ts scripts/push.ts --fix",
    "gas:typecheck": "tsx scripts/typecheck-gas.ts",
    "verify": "tsx scripts/verify.ts",
    "verify:fix": "tsx scripts/verify-fix.ts",
    "test:login": "tsx scripts/test-gdocs.ts --login",
    "test:gdocs": "tsx scripts/test-gdocs.ts",
    "test:iframe": "node scripts/test-iframe.js",
    "test:edit": "node scripts/test-edit-flow.js",
    "test:mouse": "node scripts/test-mouse.js",
    "test:cursor": "node scripts/test-cursor-in-dialog.js"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/numanaral/mermaid-toolkit-for-google-docs.git"
  },
  "author": "Numan Aral",
  "license": "MIT",
  "devDependencies": {
    "@11ty/eleventy": "^3.1.2",
    "@google/clasp": "^3.3.0",
    "@types/google-apps-script": "^2.0.8",
    "@types/node": "^25.5.0",
    "@typescript-eslint/eslint-plugin": "^8.57.0",
    "@typescript-eslint/parser": "^8.57.0",
    "concurrently": "^9.2.1",
    "esbuild": "^0.27.3",
    "eslint": "^10.0.3",
    "jiti": "^2.6.1",
    "playwright": "^1.58.2",
    "sass": "^1.97.3",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "marked": "^17.0.4",
    "mermaid": "^11.13.0"
  }
}
